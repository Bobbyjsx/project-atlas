# Local Development URLs
KEYSENTRY_URL="http://localhost:8001"
CHESS_URL="http://localhost:8002"

# ----------------------------------------------------------------------
# Local Deployment Simulation / CI Variables
# Used by envsubst to populate cloudrun-service.yaml
# ----------------------------------------------------------------------
GCP_PROJECT_ID="project-atlas-501612"
ATLAS_VERSION="latest"
KEYSENTRY_VERSION="v2.4.2"
# CHESS_VERSION="v1.2.0"

# ----------------------------------------------------------------------
# Google Secret Manager Secrets (GSM)
# Add these exact values to Google Secret Manager in Production
# ----------------------------------------------------------------------
# Name in GSM: atlas-gotrue-jwt-secret
GOTRUE_JWT_SECRET="your-gotrue-jwt-secret-here"

# Name in GSM: atlas-gotrue-url
GOTRUE_URL="https://keysentry-auth.bobslab.xyz"

# Name in GSM: keysentry-db-url
KEYSENTRY_DATABASE_URL="postgresql+asyncpg://user:password@cloud-sql-proxy:5432/db"

# Name in GSM: chess-db-url (Example if chess needs a DB)
# CHESS_DATABASE_URL="postgresql://user:password@cloud-sql-proxy:5432/chessdb"
